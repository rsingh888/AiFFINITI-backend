{
  "name": "aiffiniti-backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "dev:api_gateway": "nest start --watch",
    "dev:auth": "nest start microservices-auth --watch",
    "dev:misc": "nest start microservices-misc --watch",
    "dev:chat": "nest start microservice-chat --watch",
    "dev:post": "nest start microservice-post --watch",
    "dev:all": "concurrently -n gateway,auth,misc,chat,post -c bgMagenta,bgYellow,bgWhite,bgCyan,bgGreen \"npm run dev:api_gateway\" \"npm run dev:auth\" \"npm run dev:misc\" \"npm run dev:chat\" \"npm run dev:post\"",
    "build": "nest build",
    "build:api_gateway": "nest build",
    "build:auth": "nest build microservices-auth",
    "build:misc": "nest build microservices-misc",
    "build:chat": "nest build microservice-chat",
    "build:post": "nest build microservice-post",
    "build:all": "npm run build:api_gateway && npm run build:auth && npm run build:misc && npm run build:chat && npm run build:post",
    "start:prod_api_gateway": "node dist/apps/api-gateway/main",
    "start:prod_auth": "node dist/apps/microservices-auth/main",
    "start:prod_misc": "node dist/apps/microservices-misc/main",
    "start:prod_chat": "node dist/apps/microservice-chat/main",
    "start:prod_post": "node dist/apps/microservice-post/main",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/aiffiniti/test/jest-e2e.json",
    "drizzle:generate": "npx drizzle-kit generate",
    "drizzle:push_database": "npx drizzle-kit push"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/microservices": "^11.1.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.2",
    "@nestjs/websockets": "^11.1.2",
    "@socket.io/redis-adapter": "^8.3.0",
    "@supabase/supabase-js": "^2.49.4",
    "axios": "^1.9.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "concurrently": "^9.1.2",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.43.1",
    "ioredis": "^5.6.1",
    "mqtt": "^5.13.1",
    "pg": "^8.16.0",
    "redis": "^5.1.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@types/cookie-parser": "^1.4.8",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.18",
    "@types/pg": "^8.15.2",
    "@types/supertest": "^6.0.2",
    "drizzle-kit": "^0.31.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/"
    ]
  }
}